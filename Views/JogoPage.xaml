<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SubstitutivaJogoVelhaMVVM.Views.JogoPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Jogo">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Text="Registrar partida" Style="{StaticResource Titulo}" />
            <Label Text="Preencha os jogadores, jogue no Grid e a partida será salva automaticamente ao finalizar." Style="{StaticResource Subtitulo}" />

            <Frame>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Jogador Bolinha (O)" FontAttributes="Bold" />
                    <Entry Placeholder="Ex.: Maria" Text="{Binding NomeJogadorBolinha}" />

                    <Label Text="Jogador X" FontAttributes="Bold" />
                    <Entry Placeholder="Ex.: João" Text="{Binding NomeJogadorX}" />

                    <Button Text="Iniciar partida"
                            Command="{Binding IniciarPartidaCommand}" />
                </VerticalStackLayout>
            </Frame>

            <Frame IsVisible="{Binding PartidaIniciada}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Tabuleiro" Style="{StaticResource Titulo}" FontSize="22" />
                    <Label Text="{Binding Mensagem}" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    <Label Text="{Binding QuantidadeJogadas, StringFormat='Jogadas realizadas: {0}'}" />

                    <!-- Grid usado de forma semelhante ao AppJogoVelha estudado em sala. -->
                    <Grid RowDefinitions="*,*,*"
                          ColumnDefinitions="*,*,*"
                          RowSpacing="8"
                          ColumnSpacing="8">

                        <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource BotaoCasa}" Text="{Binding Casa0}" Command="{Binding JogarCommand}" CommandParameter="0" IsEnabled="{Binding TabuleiroAtivo}" />
                        <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource BotaoCasa}" Text="{Binding Casa1}" Command="{Binding JogarCommand}" CommandParameter="1" IsEnabled="{Binding TabuleiroAtivo}" />
                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource BotaoCasa}" Text="{Binding Casa2}" Command="{Binding JogarCommand}" CommandParameter="2" IsEnabled="{Binding TabuleiroAtivo}" />

                        <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource BotaoCasa}" Text="{Binding Casa3}" Command="{Binding JogarCommand}" CommandParameter="3" IsEnabled="{Binding TabuleiroAtivo}" />
                        <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource BotaoCasa}" Text="{Binding Casa4}" Command="{Binding JogarCommand}" CommandParameter="4" IsEnabled="{Binding TabuleiroAtivo}" />
                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource BotaoCasa}" Text="{Binding Casa5}" Command="{Binding JogarCommand}" CommandParameter="5" IsEnabled="{Binding TabuleiroAtivo}" />

                        <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource BotaoCasa}" Text="{Binding Casa6}" Command="{Binding JogarCommand}" CommandParameter="6" IsEnabled="{Binding TabuleiroAtivo}" />
                        <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource BotaoCasa}" Text="{Binding Casa7}" Command="{Binding JogarCommand}" CommandParameter="7" IsEnabled="{Binding TabuleiroAtivo}" />
                        <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource BotaoCasa}" Text="{Binding Casa8}" Command="{Binding JogarCommand}" CommandParameter="8" IsEnabled="{Binding TabuleiroAtivo}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Nova partida" Command="{Binding NovaPartidaCommand}" />
                        <Button Grid.Column="1" Text="Histórico" Style="{StaticResource BotaoSecundario}" Command="{Binding AbrirHistoricoCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
