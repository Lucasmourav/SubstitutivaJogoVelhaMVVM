<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SubstitutivaJogoVelhaMVVM.Views.HomePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Início">

    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="22">
            <!-- Bloco inicial: apresenta a identidade do app sem misturar regra de negócio na View. -->
            <Frame BackgroundColor="{StaticResource PrimarySoft}"
                   BorderColor="{StaticResource Primary}"
                   Padding="24"
                   CornerRadius="12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Avaliação SUB"
                           TextColor="{StaticResource PrimaryDark}"
                           FontSize="15"
                           FontAttributes="Bold" />
                    <Label Text="Jogo da Velha MVVM"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="30"
                           FontAttributes="Bold" />
                    <Label Text="Partidas locais com navegação Shell, tabuleiro em Grid e histórico salvo em SQLite."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="16" />
                </VerticalStackLayout>
            </Frame>

            <!-- Card explicativo para deixar claro como o projeto foi organizado. -->
            <Frame>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Fluxo do app" Style="{StaticResource Titulo}" FontSize="22" />
                    <Label Text="1. Informe os jogadores e inicie uma partida." />
                    <Label Text="2. Jogue no tabuleiro 3x3 até vitória ou empate." />
                    <Label Text="3. Consulte o histórico por nome e período." />
                </VerticalStackLayout>
            </Frame>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="14"
                  Margin="0,4,0,0">
                <Button Grid.Column="0"
                        Text="Nova partida"
                        Command="{Binding AbrirJogoCommand}" />

                <Button Grid.Column="1"
                        Text="Histórico"
                        Style="{StaticResource BotaoSecundario}"
                        Command="{Binding AbrirHistoricoCommand}" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
