<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SubstitutivaJogoVelhaMVVM.Views.HistoricoPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Historico de Partidas">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Text="Historico de Partidas" Style="{StaticResource Titulo}" />
            <Label Text="Consulte partidas salvas por jogador e periodo." Style="{StaticResource Subtitulo}" />

            <Frame>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Jogador" FontAttributes="Bold" />
                    <Entry Placeholder="Digite o nome do jogador"
                           Text="{Binding NomeJogadorFiltro}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Data inicial" FontAttributes="Bold" />
                            <DatePicker Date="{Binding DataInicio}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Data final" FontAttributes="Bold" />
                            <DatePicker Date="{Binding DataFim}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="Buscar"
                                Command="{Binding BuscarCommand}" />
                        <Button Grid.Column="1"
                                Text="Limpar"
                                Style="{StaticResource BotaoSecundario}"
                                Command="{Binding LimparCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Label Text="{Binding MensagemResultado}"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" />

            <CollectionView ItemsSource="{Binding Partidas}"
                            EmptyView="Nenhuma partida encontrada.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding DataPartida, StringFormat='Data: {0:dd/MM/yyyy HH:mm}'}"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding JogadorX, StringFormat='Jogador X: {0}'}" />
                                <Label Text="{Binding JogadorBolinha, StringFormat='Jogador O: {0}'}" />
                                <Label Text="{Binding Vencedor, StringFormat='Vencedor: {0}'}"
                                       TextColor="{StaticResource Success}"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding SimboloVencedor, StringFormat='Simbolo vencedor: {0}'}" />
                                <Label Text="{Binding QuantidadeJogadas, StringFormat='Jogadas: {0}'}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Voltar"
                    Style="{StaticResource BotaoSecundario}"
                    Command="{Binding VoltarCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
