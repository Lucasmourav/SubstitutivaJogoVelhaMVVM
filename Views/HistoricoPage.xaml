<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="SubstitutivaJogoVelhaMVVM.Views.HistoricoPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Histórico de Partidas">

    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="22">
            <Label Text="Histórico de Partidas" Style="{StaticResource Titulo}" />
            <Label Text="Filtre as partidas salvas por jogador e período."
                   Style="{StaticResource Subtitulo}" />

            <!-- Área de filtros: a tela só envia os valores para o HistoricoViewModel. -->
            <Frame>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Filtros" Style="{StaticResource Titulo}" FontSize="22" />

                    <Label Text="Jogador" FontAttributes="Bold" />
                    <Entry Placeholder="Digite o nome do jogador"
                           Text="{Binding NomeJogadorFiltro}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Data inicial" FontAttributes="Bold" />
                            <DatePicker Date="{Binding DataInicio}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Data final" FontAttributes="Bold" />
                            <DatePicker Date="{Binding DataFim}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="14" Margin="0,4,0,0">
                        <Button Grid.Column="0"
                                Text="Buscar"
                                Command="{Binding BuscarCommand}" />
                        <Button Grid.Column="1"
                                Text="Limpar"
                                Style="{StaticResource BotaoSecundario}"
                                Command="{Binding LimparCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout Spacing="8">
                <Label Text="Resultados" Style="{StaticResource Titulo}" FontSize="22" />
                <Label Text="{Binding MensagemResultado}"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}" />
            </VerticalStackLayout>

            <CollectionView ItemsSource="{Binding Partidas}"
                            EmptyView="Nenhuma partida encontrada.">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="18" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0" Padding="20">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <Label Grid.Column="0"
                                           Text="{Binding DataPartida, StringFormat='Data: {0:dd/MM/yyyy HH:mm}'}"
                                           FontAttributes="Bold" />
                                    <Label Grid.Column="1"
                                           Text="{Binding SimboloVencedor}"
                                           TextColor="{StaticResource Primary}"
                                           FontSize="22"
                                           FontAttributes="Bold" />
                                </Grid>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                    <Label Grid.Column="0"
                                           Text="{Binding JogadorX, StringFormat='X: {0}'}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding JogadorBolinha, StringFormat='O: {0}'}" />
                                </Grid>

                                <Label Text="{Binding Vencedor, StringFormat='Vencedor: {0}'}"
                                       TextColor="{StaticResource Success}"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding QuantidadeJogadas, StringFormat='Jogadas realizadas: {0}'}"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Voltar"
                    Style="{StaticResource BotaoSecundario}"
                    Command="{Binding VoltarCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
