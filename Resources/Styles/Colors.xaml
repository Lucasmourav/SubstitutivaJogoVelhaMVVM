<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <!-- Paleta clara do app: azul para ação, verde para resultados e cinzas suaves para leitura. -->
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1E40AF</Color>
    <Color x:Key="PrimarySoft">#DBEAFE</Color>
    <Color x:Key="Secondary">#0F766E</Color>
    <Color x:Key="Accent">#F59E0B</Color>
    <Color x:Key="PageBackground">#F8FAFC</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="CardBorder">#DCE7F3</Color>
    <Color x:Key="InputBackground">#F9FBFD</Color>
    <Color x:Key="TextPrimary">#0F172A</Color>
    <Color x:Key="TextSecondary">#475569</Color>
    <Color x:Key="TextMuted">#64748B</Color>
    <Color x:Key="Danger">#DC2626</Color>
    <Color x:Key="Success">#059669</Color>
</ResourceDictionary>
